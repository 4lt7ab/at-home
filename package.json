{
  "name": "@x4lt7ab/tab-at-home",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tab-at-home": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "SQLITE_PATH=.local/data/sqlite.db concurrently --kill-others --names 'api,web' \"bun run --watch src/index.ts\" \"cd src/web && vite build --watch\"",
    "build": "cd src/web && vite build",
    "start": "SQLITE_PATH=.local/data/sqlite.db bun run src/index.ts",
    "serve": "bun run build && bun run start",
    "start:mcp": "SQLITE_PATH=.local/data/sqlite.db bun run src/mcp/standalone.ts",
    "test": "bun test",
    "test:web": "cd src/web && vitest run",
    "test:web:watch": "cd src/web && vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "hono": "4.12.9",
    "ulid": "2.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "9.2.1",
    "jsdom": "^29.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vitest": "^4.1.2"
  }
}
